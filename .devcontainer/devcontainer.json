{
    "name": "Python 3 & Django",
    "image": "://microsoft.com",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "batisteo.vscode-django"
            ]
        }
    },
    "forwardPorts": [8000]
}
